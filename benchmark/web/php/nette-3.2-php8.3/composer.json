{
    "name": "sharkbench/nette-benchmark",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "nette/application": "^3.2",
        "nette/bootstrap": "^3.2",
        "nette/di": "^3.2",
        "nette/http": "^3.2",
        "nette/routing": "^3.0",
        "nette/utils": "^4.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
